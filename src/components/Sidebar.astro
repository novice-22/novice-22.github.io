---
import { getCollection } from "astro:content";
import { SITE, NAV, CATEGORIES, SOCIAL } from "../consts";

const posts = await getCollection("posts", ({ data }) => !data.draft);
const counts: Record<string, number> = {};
for (const c of CATEGORIES) {
  counts[c.slug] = posts.filter((p) => p.data.category === c.name).length;
  // 하위 분야별 글 수 (해당 카테고리 + 분야 일치)
  for (const f of c.children ?? []) {
    counts[c.slug + "/" + f.slug] = posts.filter(
      (p) => p.data.category === c.name && (p.data as any).field === f.name
    ).length;
  }
}
const pad = (n: number) => String(n).padStart(2, "0");

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<aside class="sidebar" transition:persist="sidebar">
  <div class="sidebar-body">
  <a href="/" class="brand">
    <span class="mark"><span class="at">~/</span>{SITE.title}</span><span class="cursor"></span>
  </a>
  <div class="tagline-mono">{SITE.tagline}</div>

  <div class="sb-search">
    <input
      type="search"
      id="site-search"
      class="sb-search-input"
      placeholder="검색..."
      autocomplete="off"
      aria-label="사이트 검색"
    />
    <div id="site-search-results" class="sb-search-results" hidden></div>
  </div>

  <nav class="nav-block">
    <span class="nav-label">menu</span>
    {
      NAV.map((item) => (
        <a href={item.href} class={isActive(item.href) ? "active" : ""}>
          {item.label}
        </a>
      ))
    }
  </nav>

  <div class="cat-list">
    <span class="nav-label">categories</span>
    {
      CATEGORIES.map((c) =>
        c.children ? (
          <div class="cat-group" data-open={isActive(`/categories/${c.slug}`) ? "true" : "false"}>
            <div class="cat-parent-row">
              <button class="cat-toggle" aria-expanded={isActive(`/categories/${c.slug}`) ? "true" : "false"} aria-label="하위 분야 펼치기">
                <span class="tri">›</span>
              </button>
              <a href={`/categories/${c.slug}`} class="cat-parent-link">{c.name}</a>
              <span class="count">{pad(counts[c.slug])}</span>
            </div>
            <div class="cat-children">
              {c.children.map((f) => (
                <a href={`/categories/${c.slug}/${f.slug}`}>
                  {f.name} <span class="count">{pad(counts[c.slug + "/" + f.slug])}</span>
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a href={`/categories/${c.slug}`}>
            {c.name} <span class="count">{pad(counts[c.slug])}</span>
          </a>
        )
      )
    }
  </div>

  <div class="social">
    <button class="links-toggle" aria-expanded="false" aria-controls="social-links">
      links <span class="tri">›</span>
    </button>
    <div class="social-links" id="social-links" hidden>
      {
        SOCIAL.map((s) => (
          <a href={s.href} target={s.href.startsWith("http") ? "_blank" : undefined} rel="noopener">
            {s.label} <span class="arr">↗</span>
          </a>
        ))
      }
    </div>
    <button class="theme-toggle" style="margin-top:14px;width:fit-content;">[ dark ]</button>
  </div>
  </div>
</aside>
