---
import BaseLayout from "../layouts/BaseLayout.astro";
import { ABOUT } from "../consts";
---

<BaseLayout title="소개">
  <div class="main-head">
    <h1><span class="dot"></span> {ABOUT.heading}</h1>
  </div>
  <div class="rule"></div>

  <div class="page-intro">
    {ABOUT.lines.map((l) => <p>{l}</p>)}
  </div>

  <div class="about-section">
    <span class="nav-label">interests</span>
    <div class="chips">
      {ABOUT.skills.map((s) => <span class="chip">{s}</span>)}
    </div>
  </div>

  {
    ABOUT.resume
      .filter((s) => s.items.length > 0)
      .map((s) => (
        <div class="about-section">
          <span class="nav-label">{s.label}</span>
          <div class="facts">
            {s.items.map((it) => (
              <div class="fact">
                <span class="k">{it.when}</span>
                <span class="v">
                  {it.name}
                  {it.desc && <span class="d"> — {it.desc}</span>}
                </span>
              </div>
            ))}
          </div>
        </div>
      ))
  }

  <div class="about-section">
    <span class="nav-label">contact</span>
    <a class="contact-link" href={`mailto:${ABOUT.contact}`}>{ABOUT.contact}</a>
  </div>
</BaseLayout>
