---
import "../styles/global.css";
import Sidebar from "../components/Sidebar.astro";
import { SITE } from "../consts";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
}
const { title, description = SITE.description } = Astro.props;
const fullTitle = title ? `${title} · ${SITE.title}` : `${SITE.title} — ${SITE.tagline}`;
const isHome = Astro.url.pathname === "/" || Astro.url.pathname === "";
---

<!doctype html>
<html lang="ko" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title={SITE.title} href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans+KR:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
    <script is:inline>
      // FOUC 방지: 렌더 전 테마·사이드바 상태 적용
      (function () {
        var t = localStorage.getItem("theme") || "dark";
        document.documentElement.setAttribute("data-theme", t);
        var s = localStorage.getItem("sidebar") || "collapsed";
        document.documentElement.setAttribute("data-sidebar", s);
      })();
    </script>

    <!-- Cloudflare Web Analytics (방문자 통계) -->
    <script is:inline defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "9c98ffed405b42308810c86c0bd35a05"}'></script>
  </head>
  <body>
    <div class="edge-hover" aria-hidden="true" transition:persist></div>
    <button class="side-toggle" title="사이드바 고정/해제" aria-label="사이드바 고정/해제" transition:persist>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="3" width="18" height="18" rx="2"></rect>
        <line x1="9" y1="3" x2="9" y2="21"></line>
      </svg>
    </button>
    <div class="layout">
      <Sidebar />
      <main class="main">
        {!isHome && <a href="/" class="home-link">← 홈</a>}
        <slot />
        <footer>
          <span>© {new Date().getFullYear()} {SITE.title}</span>
          <span class="built">built with <span class="accent">Astro</span> + <span class="accent">Notion</span></span>
        </footer>
      </main>
    </div>

    <script>
      // View Transitions 대응: 지속 요소(사이드바·토글)엔 한 번만 바인딩,
      // 페이지마다 바뀌는 것(본문 복사버튼·메뉴 active)은 astro:page-load 에서 갱신.
      function syncTheme() {
        var t = document.documentElement.getAttribute("data-theme");
        document.querySelectorAll(".theme-toggle").forEach(function (b) {
          b.textContent = t === "dark" ? "[ dark ]" : "[ light ]";
        });
      }

      function bindOnce() {
        if (window.__uiBound) return;
        window.__uiBound = true;
        var docEl = document.documentElement;

        // 테마 토글
        document.addEventListener("click", function (e) {
          var btn = e.target.closest && e.target.closest(".theme-toggle");
          if (!btn) return;
          var next = docEl.getAttribute("data-theme") === "dark" ? "light" : "dark";
          docEl.setAttribute("data-theme", next);
          localStorage.setItem("theme", next);
          syncTheme();
        });

        // links 토글
        document.addEventListener("click", function (e) {
          var btn = e.target.closest && e.target.closest(".links-toggle");
          if (!btn) return;
          var box = document.getElementById("social-links");
          var open = btn.getAttribute("aria-expanded") === "true";
          btn.setAttribute("aria-expanded", open ? "false" : "true");
          if (box) box.hidden = open;
        });

        // 카테고리 하위 분야 아코디언 (화살표 클릭 = 펼침/접힘, 이름 클릭 = 전체글 이동)
        document.addEventListener("click", function (e) {
          var btn = e.target.closest && e.target.closest(".cat-toggle");
          if (!btn) return;
          var group = btn.closest(".cat-group");
          var open = group.getAttribute("data-open") === "true";
          group.setAttribute("data-open", open ? "false" : "true");
          btn.setAttribute("aria-expanded", open ? "false" : "true");
        });

        // 사이드바 peek / 핀 고정 (사이드바·토글·edge 는 transition:persist 로 유지됨)
        var sidebar = document.querySelector(".sidebar");
        var toggle = document.querySelector(".side-toggle");
        var edge = document.querySelector(".edge-hover");
        if (sidebar) {
          var hideTimer;
          var pinned = function () { return docEl.getAttribute("data-sidebar") === "open"; };
          var syncPin = function () { if (toggle) toggle.classList.toggle("pinned", pinned()); };
          var show = function () { clearTimeout(hideTimer); sidebar.classList.add("peek"); };
          var scheduleHide = function () {
            clearTimeout(hideTimer);
            hideTimer = setTimeout(function () {
              if (pinned()) return;
              if (sidebar.contains(document.activeElement)) return;
              sidebar.classList.remove("peek");
            }, 180);
          };
          if (edge) edge.addEventListener("mouseenter", show);
          if (toggle) {
            toggle.addEventListener("mouseenter", show);
            toggle.addEventListener("mouseleave", scheduleHide);
            toggle.addEventListener("click", function () {
              var next = pinned() ? "collapsed" : "open";
              docEl.setAttribute("data-sidebar", next);
              localStorage.setItem("sidebar", next);
              syncPin();
              if (next === "open") show();
            });
          }
          sidebar.addEventListener("mouseenter", show);
          sidebar.addEventListener("mouseleave", scheduleHide);
          sidebar.addEventListener("focusout", scheduleHide);
          syncPin();

          // 검색 (Pagefind 실시간 드롭다운)
          var input = document.getElementById("site-search");
          var resBox = document.getElementById("site-search-results");
          if (input && resBox) {
            var pf = null, timer = null;
            var pfUrl = "/pagefind/" + "pagefind.js";
            var loadPF = function () {
              if (pf) return Promise.resolve(pf);
              return import(/* @vite-ignore */ pfUrl).then(function (m) {
                pf = m; if (pf.options) pf.options({ excerptLength: 20 }); return pf;
              }).catch(function () { return null; });
            };
            var esc = function (s) { var d = document.createElement("div"); d.textContent = s == null ? "" : s; return d.innerHTML; };
            var renderRes = function (items, q) {
              if (!items.length) { resBox.innerHTML = '<div class="sb-sr-empty">‘' + esc(q) + '’ 검색 결과가 없어요</div>'; resBox.hidden = false; return; }
              resBox.innerHTML = items.map(function (r) {
                return '<a class="sb-sr-item" href="' + esc(r.url) + '"><span class="sb-sr-title">' + esc(r.meta && r.meta.title ? r.meta.title : r.url) + '</span><span class="sb-sr-ex">' + (r.excerpt || "") + '</span></a>';
              }).join("");
              resBox.hidden = false;
            };
            var doSearch = function (q) {
              loadPF().then(function (p) {
                if (!p) { resBox.innerHTML = '<div class="sb-sr-empty">검색은 배포된 사이트에서 동작해요</div>'; resBox.hidden = false; return; }
                p.search(q).then(function (res) { Promise.all(res.results.map(function (r) { return r.data(); })).then(function (items) { renderRes(items, q); }); });
              });
            };
            input.addEventListener("input", function () {
              var q = input.value.trim(); clearTimeout(timer);
              if (!q) { resBox.hidden = true; resBox.innerHTML = ""; return; }
              timer = setTimeout(function () { doSearch(q); }, 200);
            });
            input.addEventListener("focus", loadPF);
            document.addEventListener("click", function (e) { if (!e.target.closest || !e.target.closest(".sb-search")) resBox.hidden = true; });
            input.addEventListener("keydown", function (e) { if (e.key === "Escape") { resBox.hidden = true; input.blur(); } });
          }
        }
      }

      function perPage() {
        syncTheme();
        // 사이드바가 유지되므로 현재 경로 기준으로 메뉴 active 갱신
        var path = location.pathname.replace(/\/$/, "") || "/";
        document.querySelectorAll(".nav-block a").forEach(function (a) {
          var href = a.getAttribute("href");
          var active = href === "/" ? path === "/" : path.indexOf(href) === 0;
          a.classList.toggle("active", active);
        });
        // 현재 카테고리 그룹은 자동으로 펼침
        document.querySelectorAll(".cat-group").forEach(function (g) {
          var link = g.querySelector(".cat-parent-link");
          if (link && path.indexOf(link.getAttribute("href")) === 0) {
            g.setAttribute("data-open", "true");
            var tg = g.querySelector(".cat-toggle");
            if (tg) tg.setAttribute("aria-expanded", "true");
          }
        });
        // 코드블록 복사 버튼 (본문은 페이지마다 새로 로드됨)
        document.querySelectorAll(".prose pre").forEach(function (pre) {
          if (pre.querySelector(".copy-btn")) return;
          var btn = document.createElement("button");
          btn.className = "copy-btn";
          btn.textContent = "copy";
          btn.addEventListener("click", function () {
            var code = pre.querySelector("code");
            var text = code ? code.innerText : pre.innerText;
            navigator.clipboard.writeText(text).then(function () {
              btn.textContent = "copied";
              btn.classList.add("copied");
              setTimeout(function () { btn.textContent = "copy"; btn.classList.remove("copied"); }, 1500);
            });
          });
          pre.appendChild(btn);
        });
      }

      // 전환 시 사이드바 내부 스크롤 위치 보존 (persist 요소는 DOM 이동 때 scrollTop 이 초기화됨)
      var __sbScroll = 0;
      document.addEventListener("astro:before-swap", function () {
        var sb = document.querySelector(".sidebar-body");
        if (sb) __sbScroll = sb.scrollTop;
      });
      document.addEventListener("astro:after-swap", function () {
        var sb = document.querySelector(".sidebar-body");
        if (sb) sb.scrollTop = __sbScroll;
      });

      document.addEventListener("astro:page-load", function () {
        bindOnce();
        perPage();
      });
    </script>
  </body>
</html>
